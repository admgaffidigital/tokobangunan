        window.saveProduct = async function() {
            try {
                const id = document.getElementById('prodId').value; const vNames = document.querySelectorAll('.var-name'), vPrices = document.querySelectorAll('.var-price'), vImgs = document.querySelectorAll('.var-img');
                let finalVariants = [];
                for(let i=0; i < vNames.length; i++) { if(!vNames[i].value) throw new Error("Nama varian tidak boleh ada yang kosong!"); finalVariants.push({ id: tempVariants[i].id, name: vNames[i].value, price: parseInt(vPrices[i].value) || parseInt(document.getElementById('prodBase').value) || 0, img: vImgs[i].value || "" }); }
                if(finalVariants.length === 0) throw new Error("Produk wajib memiliki minimal 1 varian ukuran/warna.");
                const pName = document.getElementById('prodName').value; if(!pName) throw new Error("Nama produk wajib diisi.");
                
                let existingReviews = [];
                if(id) { const existProd = AppState.products.find(x => x.id == id); if(existProd && existProd.reviews) existingReviews = existProd.reviews; }

                const p = { id: id ? parseInt(id) : Date.now(), name: pName, category: document.getElementById('prodCat').value || 'Umum', desc: document.getElementById('prodDesc').value, basePrice: parseInt(document.getElementById('prodBase').value) || 0, strikePrice: parseInt(document.getElementById('prodStrike').value) || 0, images: document.getElementById('prodImgs').value.split(',').map(s=>s.trim()).filter(s=>s!=="") || ["https://placehold.co/400/e2e8f0/475569?text=No+Img"], variants: finalVariants, reviews: existingReviews };
                
                if(id) { const idx = AppState.products.findIndex(x => x.id == id); AppState.products[idx] = p; } else { AppState.products.push(p); }
                if(!AppState.categories.includes(p.category)) AppState.categories.push(p.category);
                
                setLoader(true);
                await setDoc(doc(db, "products", String(p.id)), p);
                popModal(); window._closeProductForm(); window.renderAdminProducts(); window.renderAdminReviews(); window.initStore(); showToast("Data Produk Berhasil Disimpan!");
                setLoader(false);
            } catch(e) { showToast(e.message, "error"); setLoader(false); }
        }

