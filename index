        window.calcCrow = function(lat1, lon1, lat2, lon2) {
            const R = 6371, dLat = window.toRad(lat2-lat1), dLon = window.toRad(lon2-lon1), lat1Rad = window.toRad(lat1), lat2Rad = window.toRad(lat2);
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.sin(dLon/2) * Math.sin(dLon/2) * Math.cos(lat1Rad) * Math.cos(lat2Rad); 
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)); 
        }
        window.toRad = function(Value) { return Value * Math.PI / 180; }

