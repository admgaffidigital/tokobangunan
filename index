            if(localCheckoutData.totalCart < v.minPurchase) { msg.innerText = "Minimal belanja " + formatRp(v.minPurchase); msg.classList.add('text-red-500'); return; }
            localCheckoutData.voucherCode = v.code;
            if(v.type === 'discount') { localCheckoutData.discount = v.value; msg.innerText = "Sukses! Potongan " + formatRp(v.value); } 
            else if (v.type === 'freeshipping') { localCheckoutData.discount = Math.min(localCheckoutData.shippingCost, v.value); msg.innerText = "Sukses! Gratis Ongkir (Maks " + formatRp(v.value) + ")"; }
