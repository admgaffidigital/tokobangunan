        window.renderAdminBanks = function() {
            const list = document.getElementById('adminBankList'); if(AppState.payment.banks.length === 0) { list.innerHTML = "<div class=\"text-center p-8 border-2 border-dashed border-slate-200 rounded-2xl text-slate-400 text-sm font-bold bg-slate-50/50\">Belum ada rekening toko.</div>"; return; }
            list.innerHTML = AppState.payment.banks.map(b => "<div class=\"bg-white border border-slate-200 rounded-2xl p-4 flex justify-between items-center group shadow-sm hover:shadow-md transition\"><div class=\"flex items-center gap-4\"><div class=\"w-10 h-10 bg-primary-light text-primary rounded-xl flex items-center justify-center shrink-0\"><i class=\"fa-solid fa-building-columns text-sm\"></i></div><div><div class=\"font-black text-primary-dark text-sm mb-0.5 uppercase tracking-wide\">" + b.name + "</div><div class=\"font-mono text-xs text-slate-800 bg-slate-100 px-2 py-0.5 rounded-md inline-block mb-1\">" + b.acc + "</div><div class=\"text-[10px] text-slate-500 uppercase font-bold tracking-widest\">A.N: " + b.owner + "</div></div></div><div class=\"flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-opacity\"><button type=\"button\" onclick=\"editBank(" + b.id + ")\" class=\"w-7 h-7 bg-primary-light text-primary rounded-lg hover:bg-primary hover:text-white transition active:scale-90\"><i class=\"fa-solid fa-pen text-[10px]\"></i></button><button type=\"button\" onclick=\"delBank(" + b.id + ")\" class=\"w-7 h-7 bg-red-50 text-red-500 rounded-lg hover:bg-red-500 hover:text-white transition active:scale-90\"><i class=\"fa-solid fa-trash text-[10px]\"></i></button></div></div>").join('');
        }
        window.openBankForm = function() { document.getElementById('bankId').value=''; document.getElementById('bankName').value=''; document.getElementById('bankAcc').value=''; document.getElementById('bankOwner').value=''; pushModal(); const m = document.getElementById('modalFormBank'); m.classList.remove('hidden'); void m.offsetWidth; m.classList.remove('opacity-0'); m.firstElementChild.classList.remove('scale-95'); }
        window.closeBankForm = function() { popModal(); window._closeBankForm(); }
        window.editBank = function(id) { const b = AppState.payment.banks.find(x => x.id === id); if(b) { document.getElementById('bankId').value = b.id; document.getElementById('bankName').value = b.name; document.getElementById('bankAcc').value = b.acc; document.getElementById('bankOwner').value = b.owner; pushModal(); const m = document.getElementById('modalFormBank'); m.classList.remove('hidden'); void m.offsetWidth; m.classList.remove('opacity-0'); m.firstElementChild.classList.remove('scale-95'); } }
        
        window.saveBank = async function() {
            const id = document.getElementById('bankId').value, b = { id: id ? parseInt(id) : Date.now(), name: document.getElementById('bankName').value.toUpperCase(), acc: document.getElementById('bankAcc').value, owner: document.getElementById('bankOwner').value.toUpperCase() };
            if(!b.name || !b.acc || !b.owner) { showToast("Semua Kolom Wajib Diisi!", "error"); return; }
            if(id) { const idx = AppState.payment.banks.findIndex(x => x.id == id); AppState.payment.banks[idx] = b; } else { AppState.payment.banks.push(b); }
            
            setLoader(true);
            try {
                await setDoc(doc(db, "banks", String(b.id)), b);
                popModal(); window._closeBankForm(); window.renderAdminBanks(); showToast("Data Rekening Disimpan");
            } catch(e) { showToast("Gagal menyimpan bank", "error"); }
            setLoader(false);
        }

        window.delBank = function(id) { 
            showConfirm("Hapus Rekening Terpilih?", "Data Rekening Ini Akan Dihilangkan.", async () => { 
                setLoader(true);
                try {
                    AppState.payment.banks = AppState.payment.banks.filter(x => x.id !== id); 
                    await deleteDoc(doc(db, "banks", String(id)));
                    window.renderAdminBanks(); showToast("Rekening Terhapus"); 
                } catch(e) { showToast("Gagal menghapus", "error"); }
                setLoader(false);
            }); 
        }

        window._closeVoucherForm = function() {
            const m = document.getElementById('modalFormVoucher'); if(!m.classList.contains('hidden')) { m.classList.add('opacity-0'); m.firstElementChild.classList.add('scale-95'); setTimeout(() => m.classList.add('hidden'), 300); }
        }
        window.renderAdminVouchers = function() {
            const list = document.getElementById('adminVoucherList'); if(AppState.vouchers.length === 0) { list.innerHTML = "<div class=\"col-span-full text-center p-8 border-2 border-dashed border-slate-200 rounded-3xl text-slate-400 text-sm font-bold bg-slate-50/50\">Belum ada kupon promo aktif.</div>"; return; }
            list.innerHTML = AppState.vouchers.map(v => "<div class=\"bg-white border " + (v.type === 'discount' ? 'border-orange-200' : 'border-emerald-200') + " rounded-3xl p-5 relative overflow-hidden group shadow-sm hover:shadow-md transition\"><div class=\"absolute -top-4 -right-4 p-2 opacity-10 transform group-hover:scale-110 transition duration-500\"><i class=\"fa-solid " + (v.type === 'discount' ? 'fa-tags text-orange-600' : 'fa-truck-fast text-emerald-600') + " text-7xl\"></i></div><div class=\"relative z-10\"><div class=\"flex justify-between items-start mb-3\"><span class=\"font-black text-xs bg-slate-900 text-white px-3 py-1.5 rounded-lg tracking-widest shadow-md\">" + v.code + "</span><button type=\"button\" onclick=\"delVoucher(" + v.id + ")\" class=\"text-slate-300 hover:text-red-500 transition text-base\"><i class=\"fa-solid fa-trash\"></i></button></div><div class=\"text-lg font-black " + (v.type === 'discount' ? 'text-orange-600' : 'text-emerald-600') + " mb-1.5\">" + (v.type === 'discount' ? ("Diskon Rp " + formatRp(v.value)) : ("Gratis Ongkir maks Rp " + formatRp(v.value))) + "</div><div class=\"text-[10px] text-slate-500 font-bold bg-slate-100 px-2 py-1 rounded inline-block\">Minimal Pembelian: " + formatRp(v.minPurchase) + "</div></div></div>").join('');
        }
        window.openVoucherForm = function() { document.getElementById('vouchId').value = ''; ['vouchCode','vouchValue','vouchMin'].forEach(id => document.getElementById(id).value = ''); pushModal(); const m = document.getElementById('modalFormVoucher'); m.classList.remove('hidden'); void m.offsetWidth; m.classList.remove('opacity-0'); m.firstElementChild.classList.remove('scale-95'); }
        window.closeVoucherForm = function() { popModal(); window._closeVoucherForm(); }
        
        window.saveVoucher = async function() {
            const v = { id: Date.now(), code: document.getElementById('vouchCode').value.toUpperCase().replace(/\s/g, ''), type: document.getElementById('vouchType').value, value: parseInt(document.getElementById('vouchValue').value) || 0, minPurchase: parseInt(document.getElementById('vouchMin').value) || 0 };
            if(!v.code || v.value <= 0) { showToast("Kode atau Nilai tidak boleh kosong", "error"); return; }
            AppState.vouchers.push(v); 
            
            setLoader(true);
            try {
                await setDoc(doc(db, "vouchers", String(v.id)), v);
                popModal(); window._closeVoucherForm(); window.renderAdminVouchers(); showToast("Kupon Promo Aktif!");
            } catch (e) { showToast("Gagal menyimpan voucher", "error"); }
            setLoader(false);
        }

        window.delVoucher = function(id) { 
            showConfirm("Hapus Promo Ini?", "Kode kupon tidak akan bisa dipakai lagi oleh pelanggan.", async () => { 
                setLoader(true);
                try {
                    AppState.vouchers = AppState.vouchers.filter(x => x.id !== id); 
                    await deleteDoc(doc(db, "vouchers", String(id)));
                    window.renderAdminVouchers(); showToast("Kupon Promo Dinonaktifkan"); 
                } catch(e) { showToast("Gagal menghapus voucher", "error"); }
                setLoader(false);
            }); 
        }

        // INIT LOAD
        document.getElementById('globalLoader').classList.remove('hidden');
        window.loadCloudData();
        
    //]]>
    </script>
</body>
</html>
